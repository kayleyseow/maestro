{
  "manifest_version": 3,
  "name": "Maestro",
  "version": "0.1.0",
  "description": "Premium playback controls for Instagram videos — speed, scrubber, volume, and more.",
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://instagram.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
